{
  "manifest_version": 3,
  "name": "Perplexity Selection Search",
  "version": "1.2.0",
  "description": "Highlight text, right-click, and either fill or instantly search on Perplexity.",
  "permissions": ["contextMenus", "tabs", "scripting"],
  "host_permissions": ["https://www.perplexity.ai/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Perplexity Selection Search"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}